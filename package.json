{
  "name": "workspace-injector",
  "displayName": "Workspace Injector",
  "description": "Open a workspace file and rewrite its folders so the currently opened folder becomes the primary entry.",
  "version": "0.0.1",
  "publisher": "erikbaender",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erikbaender/workspace-injector.git"
  },
  "bugs": {
    "url": "https://github.com/erikbaender/workspace-injector/issues"
  },
  "homepage": "https://github.com/erikbaender/workspace-injector#readme",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "workspaceInjector.openWorkspaceWithCurrentFolder",
        "title": "Inject Open Folder Into Workspace",
        "category": "Workspace Injector"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "workspaceInjector.openWorkspaceWithCurrentFolder"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "vscode:prepublish": "npm run build",
    "package": "vsce package",
    "publish:vsce": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.5.4"
  }
}
